# API Keys - Copy this file to .env and fill in your keys

# Chat Model API Keys
DEEPSEEK_API_KEY=your_deepseek_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
QWEN_API_KEY=your_qwen_api_key_here

# Note: QWEN_API_KEY is used for both Qwen/Aliyun chat and embedding models
# Aliyun and Qwen are the same provider (Alibaba Cloud)

# Embedding Model API Keys
OPENAI_EMBED_API_KEY=your_openai_embed_api_key_here

# Parser API Keys
MINERU_API_KEY=your_mineru_api_key_here

# Web Search API Keys (optional - ddgs doesn't need API key)
GOOGLE_SEARCH_API_KEY=your_google_search_api_key_here
BING_SEARCH_API_KEY=your_bing_search_api_key_here
